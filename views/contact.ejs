<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Contact EnDecLab | Support & Feedback | Muhammad Yasir</title>
  
  <!-- Page-specific SEO -->
  <meta name="description" content="Contact EnDecLab - Get support, feedback or ask questions about our cryptography learning platform. Reach out via email, Instagram, LinkedIn or Facebook. We're here to help!">
  <meta name="keywords" content="contact EnDecLab, cryptography support, technical help, feedback, Muhammad Yasir contact, cryptography questions, platform support, educational support, cybersecurity help, Instagram endeclab.official, LinkedIn endeclab, Facebook endeclab, social media contact">
  
  <!-- Open Graph for Contact -->
  <meta property="og:title" content="Contact EnDecLab | Get in Touch | Cryptography Learning Platform">
  <meta property="og:description" content="Contact EnDecLab - Get in touch with us for questions, feedback, or collaboration opportunities related to cryptography education and learning.">
  <meta property="og:url" content="https://endeclab.xyz/contact">
  
  <!-- Twitter Card for Contact -->
  <meta property="twitter:title" content="Contact EnDecLab | Get in Touch">
  <meta property="twitter:description" content="Contact EnDecLab - Get in touch with us for questions, feedback, or collaboration opportunities related to cryptography education and learning.">
  
  <!-- Canonical URL -->
  <link rel="canonical" href="https://endeclab.xyz/contact">
  
  <%- include('partials/head') %>
  
  <!-- Contact Page Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact EnDecLab",
    "description": "Contact page for EnDecLab cryptography learning platform",
    "url": "https://endeclab.xyz/contact",
    "mainEntity": {
      "@type": "Organization",
      "name": "EnDecLab",
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "email": "info.endeclab@gmail.com",
          "availableLanguage": "English"
        },
        {
          "@type": "ContactPoint",
          "contactType": "technical support",
          "email": "info.endeclab@gmail.com",
          "availableLanguage": "English"
        }
      ],
      "sameAs": [
        "https://www.instagram.com/endeclab.official/",
        "https://www.linkedin.com/company/endeclab/",
        "https://www.facebook.com/share/1FokRnaVNm/?mibextid=wwXIfr"
      ]
    },
    "potentialAction": {
      "@type": "CommunicateAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "mailto:info.endeclab@gmail.com",
        "inLanguage": "en"
      },
      "expectsAcceptanceOf": {
        "@type": "Offer",
        "category": "Contact Support"
      }
    }
  }
  </script>
</head>
<body class="contact-lab">
  <%- include('partials/header') %>
  <section class="contact-hero-section">
    <div class="contact-hero-content">
      <div class="contact-hero-left">
        <div class="contact-hero-title">Contact Support</div>
        <div class="contact-hero-subtitle">We're here to help! Reach out with your questions, feedback, or suggestions.</div>
      </div>
      <div class="contact-hero-right">
        <img src="/images/logo.webp" alt="EnDecLab Logo" class="contact-logo-img" />
      </div>
    </div>
  </section>
  <main class="contact-main">
    <div class="contact-process-row">
      <div class="contact-card contact-form-card" style="position:relative;overflow:visible;background:rgba(30,40,60,0.45);backdrop-filter:blur(10px);box-shadow:0 8px 32px 0 rgba(0,216,255,0.13);border:1.5px solid rgba(0,216,255,0.18);display:flex;flex-direction:column;align-items:center;min-width:260px;max-width:370px;padding:2.2rem 1.2rem 1.7rem 1.2rem;">
        <div style="position:absolute;top:10px;right:10px;opacity:0.08;font-size:5.5rem;pointer-events:none;z-index:0;">
          <i class="fas fa-paper-plane"></i>
        </div>
        <div style="z-index:1;display:flex;flex-direction:column;align-items:center;width:100%;">
          <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,var(--primary-color),var(--accent-color));display:flex;align-items:center;justify-content:center;box-shadow:0 2px 12px rgba(0,216,255,0.10);margin-bottom:0.7rem;">
            <i class="fas fa-comment-dots" style="color:#fff;font-size:2.3rem;"></i>
          </div>
          <h3 style="color:var(--primary-color);font-family:'Orbitron',sans-serif;font-size:1.13rem;margin:0 0 1.1rem 0;letter-spacing:1px;font-weight:700;text-shadow:0 2px 12px #00d8ff22;">Send Us a Message</h3>
          <form id="contactForm" class="contact-form" novalidate style="width:100%;margin-top:0.5rem;">
            <div class="form-group">
              <label for="name">Your Name</label>
              <input type="text" name="name" id="name" required placeholder="Enter your name" />
            </div>
            <div class="form-group">
              <label for="email">Your Email</label>
              <input type="email" name="email" id="email" required placeholder="e.g. abc@example.com" />
            </div>
            <div class="form-group">
              <label for="message">Your Message</label>
              <textarea name="message" id="message" rows="5" required placeholder="Write your message here..."></textarea>
            </div>
            <div class="form-group" style="text-align: center;">
              <button type="submit" class="action-button">Send Message</button>
            </div>
          </form>
        </div>
      </div>
      <div class="contact-card contact-info-card" style="position:relative;overflow:visible;background:rgba(30,40,60,0.45);backdrop-filter:blur(10px);box-shadow:0 8px 32px 0 rgba(0,216,255,0.13);border:1.5px solid rgba(0,216,255,0.18);display:flex;flex-direction:column;align-items:center;min-width:260px;max-width:370px;padding:2.2rem 1.2rem 1.7rem 1.2rem;">
        <div style="position:absolute;top:10px;right:10px;opacity:0.08;font-size:5.5rem;pointer-events:none;z-index:0;">
          <i class="fas fa-address-book"></i>
        </div>
        <div style="z-index:1;display:flex;flex-direction:column;align-items:center;width:100%;">
          <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,var(--primary-color),var(--accent-color));display:flex;align-items:center;justify-content:center;box-shadow:0 2px 12px rgba(0,216,255,0.10);margin-bottom:0.7rem;">
            <i class="fas fa-user-circle" style="color:#fff;font-size:2.7rem;"></i>
          </div>
          <h3 style="color:var(--primary-color);font-family:'Orbitron',sans-serif;font-size:1.13rem;margin:0 0 1.1rem 0;letter-spacing:1px;font-weight:700;text-shadow:0 2px 12px #00d8ff22;">Direct Contact</h3>
          <div style="width:100%;display:flex;flex-direction:column;gap:0.7rem;align-items:center;">
            <a href="mailto:info.endeclab@gmail.com" class="contact-pill" style="background:rgba(0,216,255,0.13);color:var(--primary-color);"> <i class="fas fa-envelope"></i> info.endeclab@gmail.com</a>
            <a href="https://www.linkedin.com/company/endeclab/" target="_blank" class="contact-pill" style="background:rgba(0,255,170,0.13);color:#00ffaa;"> <i class="fab fa-linkedin"></i> EnDecLab Company</a>
            <a href="https://www.instagram.com/endeclab.official/" target="_blank" class="contact-pill" style="background:rgba(255,0,170,0.13);color:#ff00aa;"> <i class="fab fa-instagram"></i> @endeclab.official</a>
            <a href="https://www.facebook.com/share/1FokRnaVNm/?mibextid=wwXIfr" target="_blank" class="contact-pill" style="background:rgba(224, 235, 13, 0.13);color:#fff700e7;"> <i class="fab fa-facebook"></i> EnDecLab Facebook</a>
          </div>
        </div>
      </div>
    </div>
    <div id="thankYouPopup">
      <h2>🎉 Message Sent!</h2>
      <p>Thank you for reaching out. I'll get back to you soon.</p>
      <button class="action-button" id="closePopupBtn">Close</button>
    </div>
    <div id="errorPopup" style="display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(40,10,30,0.97);padding:2rem 3rem;border-radius:1.1rem;border:2.5px solid #ff3366;box-shadow:0 0 30px #ff336655;color:var(--light-text);z-index:9999;text-align:center;min-width:270px;">
      <h2 style="color:#ff3366;">Error</h2>
      <p id="errorPopupMsg">Something went wrong. Please try again.</p>
      <button class="action-button" id="closeErrorPopupBtn" style="background:linear-gradient(90deg,#ff3366,#ff00aa);border:2px solid #ff3366;color:#fff;">Close</button>
    </div>
  </main>
  <style>
    body.contact-lab {
      background: var(--dark-bg);
      min-height: 100vh;
      color: var(--light-text);
    }
    .contact-hero-section {
      width: 100%;
      min-height: 260px;
      margin: 0 auto 2.5rem auto;
      background: linear-gradient(120deg, rgba(0,216,255,0.10) 0%, rgba(255,0,170,0.08) 100%);
      position: relative;
      border-radius: 0 0 2.5rem 2.5rem;
      box-shadow: 0 4px 32px 0 rgba(0,216,255,0.08);
      overflow: hidden;
      z-index: 1;
      backdrop-filter: blur(2px);
      display: block;
    }
    .contact-hero-content {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1100px;
      margin: 0 auto;
      padding: 2.5rem 2rem 1.5rem 2rem;
      gap: 2.5rem;
    }
    .contact-hero-left {
      flex: 1 1 340px;
      min-width: 220px;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      z-index: 2;
    }
    .contact-hero-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 2.3rem;
      background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 0 18px rgba(0,216,255,0.18);
      margin-bottom: 0.5rem;
    }
    .contact-hero-subtitle {
      font-size: 1.15rem;
      color: var(--secondary-color);
      font-family: 'Orbitron', sans-serif;
      margin-bottom: 0.7rem;
      font-weight: 500;
      letter-spacing: 1px;
    }
    .contact-logo-img {
      width: 220px;
      max-width: 95vw;
      height: auto;
      display: block;
      margin: 0 auto;
      filter: drop-shadow(0 0 24px var(--primary-color));
      border-radius: 1.2rem;
      background: rgba(0,216,255,0.04);
      padding: 0.5rem 1rem;
      animation: heroLogoBounce 2s ease-in-out infinite alternate;
    }
    @keyframes heroLogoBounce {
      0% { transform: translateY(0); }
      100% { transform: translateY(-18px); }
    }
    .contact-main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1.5rem 0.7rem 2.5rem 0.7rem;
    }
    .contact-process-row {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      justify-content: center;
      margin: 0 auto 2.5rem auto;
    }
    .contact-card {
      background: rgba(20, 20, 40, 0.7);
      border-radius: 1.1rem;
      box-shadow: 0 2px 10px rgba(0,216,255,0.07);
      padding: 1.5rem 1.2rem 1.5rem 1.2rem;
      min-width: 280px;
      max-width: 420px;
      flex: 1 1 320px;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      border: 1.5px solid var(--primary-color);
      opacity: 1;
      transition: all 0.3s cubic-bezier(.4,2,.6,1) !important;
      margin-bottom: 0.5rem;
    }
    .contact-card h3 {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.18rem;
      color: var(--primary-color);
      text-align: center;
      margin-bottom: 1.1rem;
      margin-top: 0.2rem;
    }
    .form-group label {
      font-family: 'Orbitron', sans-serif;
      color: var(--primary-color);
      font-size: 0.98rem;
      margin-bottom: 0.3rem;
      display: block;
    }
    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 0.7rem;
      background-color: rgba(20, 20, 40, 0.8);
      border: 1px solid rgba(0, 216, 255, 0.2);
      border-radius: 4px;
      color: var(--light-text);
      font-family: 'Roboto Mono', monospace;
      font-size: 1rem;
      margin-bottom: 0.7rem;
      resize: vertical;
    }
    .form-group textarea {
      min-height: 80px;
      max-height: 180px;
    }
    .action-button {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.01rem;
      font-weight: 700;
      padding: 0.7rem 2rem;
      border-radius: 2rem;
      border: none;
      background: linear-gradient(90deg, var(--primary-color) 60%, var(--accent-color) 100%);
      color: var(--dark-bg);
      margin-top: 0.7rem;
      box-shadow: 0 2px 12px rgba(0,216,255,0.10);
      cursor: pointer;
      letter-spacing: 1px;
      transition: background 0.18s, color 0.18s, transform 0.15s;
      display: inline-block;
      min-width: 120px;
    }
    .action-button:disabled {
      background: rgba(0,216,255,0.13);
      color: var(--dark-text);
      cursor: not-allowed;
      box-shadow: none;
    }
    .action-button:hover:not(:disabled), .action-button:focus:not(:disabled) {
      background: linear-gradient(90deg, var(--accent-color) 60%, var(--primary-color) 100%);
      color: var(--lighter-text);
      transform: translateY(-2px) scale(1.04);
    }
    .info-content {
      background: rgba(20, 20, 40, 0.7);
      border-radius: 1.1rem;
      box-shadow: 0 2px 10px rgba(0,216,255,0.07);
      padding: 1.2rem 1.1rem 1.2rem 1.3rem;
      margin-bottom: 1.2rem;
      border: 1.5px solid var(--primary-color);
      opacity: 1;
      transform: none;
      transition: all 0.7s cubic-bezier(.4,2,.6,1), box-shadow 0.25s, background 0.25s, transform 0.25s;
      cursor: pointer;
      text-align: left;
      line-height: 1.7;
    }
    .info-content p, .info-content strong, .info-content h4, .info-content li {
      color: var(--light-text);
      font-size: 1.01rem;
      text-align: left;
      line-height: 1.7;
    }
    .info-content h4 {
      margin-top: 1.2rem;
      margin-bottom: 0.7rem;
      font-size: 1.08rem;
      font-family: 'Orbitron', sans-serif;
      color: var(--primary-color);
    }
    .info-content ol, .info-content ul {
      margin-left: 1.2rem;
      margin-bottom: 1rem;
      padding-left: 1.2rem;
    }
    .info-content li {
      margin-bottom: 0.4rem;
    }
    .social-icons {
      margin-top: 0.7rem;
      display: flex;
      justify-content: flex-start;
      gap: 1.2rem;
    }
    .social-icons a {
      color: #00d8ff;
      font-size: 1.7rem;
      transition: transform 0.3s, color 0.3s;
      filter: drop-shadow(0 0 8px #0fffc155);
    }
    .social-icons a:hover {
      transform: scale(1.22) rotate(-8deg);
      color: #6f00ff;
      filter: drop-shadow(0 0 18px #6f00ff99);
    }
    #thankYouPopup {
      display: none;
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: rgba(20, 20, 40, 0.97);
      padding: 2rem 3rem;
      border-radius: 1.1rem;
      border: 2.5px solid #0fffc1;
      box-shadow: 0 0 30px #00d8ff55;
      color: var(--light-text);
      z-index: 10000;
      text-align: center;
      min-width: 270px;
      backdrop-filter: blur(10px);
    }
    #thankYouPopup button {
      margin-top: 1.5rem;
      padding: 0.7rem 1.5rem;
      border: none;
      background: linear-gradient(90deg, #0fffc1, #00d8ff, #6f00ff);
      color: #000;
      border-radius: 10px;
      cursor: pointer;
      font-family: 'Orbitron', sans-serif;
      font-size: 1.07rem;
      font-weight: 700;
      transition: background 0.3s, box-shadow 0.3s;
      border: 2px solid #0fffc1;
      letter-spacing: 1px;
    }
    #thankYouPopup button:hover {
      background: linear-gradient(90deg, #6f00ff, #00d8ff, #0fffc1);
      box-shadow: 0 0 18px #6f00ff55;
      border: 2px solid #6f00ff;
    }
    @media (max-width: 900px) {
      .contact-process-row {
        flex-direction: column;
        gap: 1.5rem;
        align-items: stretch;
      }
      .contact-card {
        max-width: 100%;
        min-width: 0;
      }
    }
    @media (max-width: 600px) {
      .contact-main {
        padding: 1.2rem 0.1rem 0.8rem 0.1rem;
      }
      .contact-process-row {
        display: block;
        width: 100%;
      }
      .contact-card {
        display: block;
        width: 100%;
        min-width: unset;
        max-width: unset;
        margin-bottom: 1.1rem;
        padding: 0.8rem 0.4rem 0.8rem 0.4rem;
      }
      .contact-hero-title {
        font-size: 1.8rem;
        text-align: center;
      }
      .contact-hero-subtitle {
        font-size: 1rem;
        text-align: center;
      }
      #thankYouPopup {
        padding: 1.2rem 0.7rem;
      }
    }
    @media (max-width: 480px) {
      .contact-hero-section {
        min-height: 120px;
        border-radius: 0 0 1rem 1rem;
        margin-bottom: 1rem;
      }
      .contact-hero-content {
        flex-direction: column-reverse;
        padding: 1rem 0.8rem 0.8rem 0.8rem;
        gap: 1rem;
      }
      .contact-hero-title {
        font-size: 1.5rem;
      }
      .contact-hero-subtitle {
        font-size: 0.9rem;
      }
      .contact-logo-img {
        width: 150px;
        padding: 0.2rem 0.6rem;
      }
    }
    @media (max-width: 360px) {
      .contact-hero-content {
        flex-direction: column-reverse;
        padding: 0.8rem 0.6rem 0.6rem 0.6rem;
      }
      .contact-hero-title {
        font-size: 1.3rem;
      }
      .contact-hero-subtitle {
        font-size: 0.8rem;
      }
      .contact-logo-img {
        width: 120px;
      }
    }
    @keyframes heroLogoBounce {
      0% { transform: translateY(0); }
      100% { transform: translateY(-18px); }
    }
  </style>
  <script>
    const form = document.getElementById("contactForm");
    const thankYouPopup = document.getElementById("thankYouPopup");
    const errorPopup = document.getElementById("errorPopup");
    const errorPopupMsg = document.getElementById("errorPopupMsg");
    const closePopupBtn = document.getElementById("closePopupBtn");
    const closeErrorPopupBtn = document.getElementById("closeErrorPopupBtn");

    form.addEventListener("submit", async function (e) {
      e.preventDefault();

      const formData = new FormData(form);
      const email = formData.get("email");
      // Simple email validation
      if (!/^\S+@\S+\.\S+$/.test(email)) {
        showErrorPopup("Please enter a valid email address.");
        return;
      }
      try {
        const response = await fetch("https://formspree.io/f/myzjgqwy", {
          method: "POST",
          body: formData,
          headers: { Accept: "application/json" },
        });

        if (response.ok) {
          form.reset();
          thankYouPopup.style.display = "block";
        } else {
          showErrorPopup("Oops! Something went wrong. Please try again.");
        }
      } catch (error) {
        showErrorPopup("Failed to send. Please check your connection.");
      }
    });

    closePopupBtn.addEventListener("click", closePopup);
    closeErrorPopupBtn.addEventListener("click", closeErrorPopup);

    function closePopup() {
      thankYouPopup.style.display = "none";
    }
    
    function showErrorPopup(msg) {
      errorPopupMsg.textContent = msg;
      errorPopup.style.display = "block";
    }
    
    function closeErrorPopup() {
      errorPopup.style.display = "none";
    }

    // Close popup when clicking outside
    document.addEventListener('click', function(e) {
      if (e.target === thankYouPopup) {
        closePopup();
      }
      if (e.target === errorPopup) {
        closeErrorPopup();
      }
    });

    // Close popup with Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closePopup();
        closeErrorPopup();
      }
    });

    // Animate cards on scroll
    document.addEventListener('DOMContentLoaded', function() {
      const cards = document.querySelectorAll('.contact-card');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
          }
        });
      }, { threshold: 0.2 });
      cards.forEach(card => observer.observe(card));
    });
  </script>
  <%- include('partials/footer') %>
</body>
</html>
