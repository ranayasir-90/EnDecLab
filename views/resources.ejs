  <script>
    const resourceDetails = {
      caesar: {
        title: "Caesar Cipher",
        description: "A simple substitution cipher where each letter in the plaintext is shifted by a fixed number of positions.",
        details: `The Caesar cipher is one of the oldest and most well-known ciphers. It works by shifting each letter of the plaintext by a fixed number (the key) down the alphabet. For example, with a shift of 3, A becomes D, B becomes E, and so on. The cipher is easy to break using frequency analysis, but it is a great introduction to classical cryptography.\n\n<em>Example:</em> Plaintext: HELLO, Key: 3 → Ciphertext: KHOOR.\n\n<em>Applications:</em> Simple puzzles, children's games, and historical study.`,
        link: "https://en.wikipedia.org/wiki/Caesar_cipher"
      },
      affine: {
        title: "Affine Cipher",
        description: "A type of monoalphabetic substitution cipher based on mathematical functions.",
        details: `The Affine cipher uses mathematical functions to encrypt each letter. The formula is E(x) = (ax + b) mod m, where 'a' and 'b' are keys, and 'm' is the size of the alphabet.\n\n<em>Example:</em> With a=5, b=8, and m=26, plaintext A (0) becomes I (8).\n\n<em>Note:</em> The key 'a' must be coprime with 26 for the cipher to be reversible.\n\n<em>Applications:</em> Educational, demonstrates algebraic concepts in cryptography.`,
        link: "https://en.wikipedia.org/wiki/Affine_cipher"
      },
      railfence: {
        title: "Rail Fence Cipher",
        description: "A transposition cipher that writes the message in a zigzag pattern.",
        details: `The Rail Fence cipher is a simple transposition cipher. The plaintext is written in a zigzag pattern across multiple 'rails' (rows), then read row by row to create the ciphertext.\n\n<em>Example:</em> Plaintext: ATTACKATDAWN, Rails: 3\nA . . . C . . . T . . . W . .\n. T . K . T . D . A . N .\n. . T . . . A . . . N . .\nCiphertext: ACTWKTDAATN\n\n<em>Applications:</em> Simple puzzles, teaching transposition concepts.`,
        link: "https://en.wikipedia.org/wiki/Rail_fence_cipher"
      },
      transposition: {
        title: "Transposition Cipher",
        description: "A cipher that rearranges the letters of the plaintext without changing them.",
        details: `Transposition ciphers work by rearranging the order of the letters in the plaintext according to a certain system or key. Unlike substitution ciphers, the actual letters are not changed, only their positions.\n\n<em>Example:</em> Columnar transposition with key 4312567.\n\n<em>Strengths:</em> Can be combined with substitution ciphers for greater security.\n<em>Weaknesses:</em> Vulnerable to anagramming and pattern analysis.`,
        link: "https://en.wikipedia.org/wiki/Transposition_cipher"
      },
      rot13: {
        title: "ROT13",
        description: "A special case of the Caesar cipher with a fixed shift of 13.",
        details: `ROT13 is a simple letter substitution cipher that replaces a letter with the 13th letter after it in the alphabet. Because the alphabet has 26 letters, applying ROT13 twice returns the original text.\n\n<em>Example:</em> HELLO → URYYB\n\n<em>Applications:</em> Obfuscating spoilers, jokes, or answers in online forums. Not secure for real encryption.`,
        link: "https://en.wikipedia.org/wiki/ROT13"
      },
      'digital-signatures': {
        title: "Digital Signatures",
        description: "Cryptographic technique for verifying authenticity and integrity.",
        details: `Digital signatures are used to verify the authenticity and integrity of digital messages or documents. They use asymmetric cryptography, where a private key is used to sign and a public key is used to verify.\n\n<em>How it works:</em> The sender creates a hash of the message and encrypts it with their private key. The recipient decrypts the hash with the sender's public key and compares it to the hash of the received message.\n\n<em>Applications:</em> Secure email, software distribution, legal documents.`,
        link: "https://en.wikipedia.org/wiki/Digital_signature"
      },
      rsa: {
        title: "RSA Signatures",
        description: "A widely used public key signature algorithm.",
        details: `RSA is one of the first public-key cryptosystems and is widely used for secure data transmission and digital signatures. Its security is based on the difficulty of factoring large integers.\n\n<em>How it works:</em> The sender signs a message by encrypting its hash with their private RSA key. The recipient verifies by decrypting with the sender's public key.\n\n<em>Applications:</em> SSL/TLS, secure email, digital certificates.`,
        link: "https://en.wikipedia.org/wiki/RSA_(cryptosystem)"
      },
      ecdsa: {
        title: "ECDSA",
        description: "Elliptic Curve Digital Signature Algorithm.",
        details: `ECDSA is a variant of the Digital Signature Algorithm (DSA) that uses elliptic curve cryptography. It offers the same level of security as RSA but with much smaller key sizes, making it efficient for mobile and embedded devices.\n\n<em>Applications:</em> Bitcoin, blockchain, secure messaging, and modern web security.`,
        link: "https://en.wikipedia.org/wiki/Elliptic_Curve_Digital_Signature_Algorithm"
      },
      'hash-functions': {
        title: "Hash Functions",
        description: "Algorithms that map data to a fixed-size string (hash).",
        details: `Hash functions take an input (or 'message') and return a fixed-size string of bytes. A good hash function is fast, irreversible, and produces unique outputs for different inputs.\n\n<em>Examples:</em> SHA-256, SHA-3, BLAKE2, MD5.\n\n<em>Applications:</em> Password storage, digital signatures, data integrity, blockchain.`,
        link: "https://en.wikipedia.org/wiki/Cryptographic_hash_function"
      },
      'signature-lab': {
        title: "Signature Lab",
        description: "Interactive lab to experiment with digital signatures.",
        details: `The Signature Lab lets you try out creating and verifying digital signatures using different algorithms. You can see how private and public keys work, and how signatures ensure authenticity.\n\n<em>Try it:</em> Experiment with RSA and ECDSA signatures, and see how tampering with data breaks verification.`,
        link: "/signature-lab"
      },
      steganography: {
        title: "What is Steganography?",
        description: "The practice of hiding information within other non-secret data.",
        details: `Steganography is the art and science of hiding information in such a way that its presence is concealed. Unlike cryptography, which hides the content, steganography hides the fact that a message exists at all.\n\n<em>Examples:</em> Hiding text in images, audio files, or even within other text.\n\n<em>Applications:</em> Covert communication, watermarking, copyright protection.`,
        link: "https://en.wikipedia.org/wiki/Steganography"
      },
      lsb: {
        title: "LSB Technique",
        description: "Least Significant Bit (LSB) method for image steganography.",
        details: `The LSB technique hides information by replacing the least significant bits of image pixels with bits from the secret message. This change is usually imperceptible to the human eye.\n\n<em>Example:</em> Hiding a text message in the blue channel of a PNG image.\n\n<em>Applications:</em> Digital watermarking, secret communication.`,
        link: "https://en.wikipedia.org/wiki/Least_significant_bit"
      },
      'stego-vs-crypto': {
        title: "Stego vs Crypto",
        description: "Comparison between steganography and cryptography.",
        details: `Steganography and cryptography are both used to protect information, but in different ways. Cryptography scrambles the content so it can't be read without a key, while steganography hides the fact that a message exists at all.\n\n<em>Combined use:</em> For maximum security, a message can be encrypted and then hidden using steganography.\n\n<em>Applications:</em> Secure communication, anti-censorship.`,
        link: "https://en.wikipedia.org/wiki/Steganography#Comparison_with_cryptography"
      },
      'steganography-lab': {
        title: "Steganography Lab",
        description: "Interactive lab to try steganography techniques.",
        details: `The Steganography Lab lets you experiment with hiding and extracting messages in images. You can see how LSB and other techniques work, and learn about the strengths and weaknesses of steganography.\n\n<em>Try it:</em> Hide a secret message in an image and share it with a friend!` ,
        link: "/steganography-lab"
      },
      'file-encryption': {
        title: "File Encryption",
        description: "The process of encoding files to prevent unauthorized access.",
        details: `File encryption uses algorithms to convert files into unreadable formats, only accessible with the correct key. It protects sensitive data from unauthorized access, even if the file is stolen.\n\n<em>Types:</em> Symmetric (same key for encryption/decryption) and asymmetric (public/private keys).\n\n<em>Applications:</em> Secure storage, cloud security, email attachments.`,
        link: "https://en.wikipedia.org/wiki/File_encryption"
      },
      aes: {
        title: "AES",
        description: "Advanced Encryption Standard, a modern symmetric encryption algorithm.",
        details: `AES is the most widely used symmetric encryption algorithm today. It is fast, secure, and used in everything from Wi-Fi to banking. AES supports 128, 192, and 256-bit keys.\n\n<em>How it works:</em> AES operates on blocks of data using a series of substitutions and permutations.\n\n<em>Applications:</em> VPNs, disk encryption, SSL/TLS, file encryption.`,
        link: "https://en.wikipedia.org/wiki/Advanced_Encryption_Standard"
      },
      kdf: {
        title: "KDF (Key Derivation Function)",
        description: "Converts passwords into cryptographic keys.",
        details: `KDFs are algorithms that turn a password into a strong cryptographic key, often by adding a salt and performing many rounds of computation. This makes it much harder for attackers to guess passwords using brute force.\n\n<em>Examples:</em> PBKDF2, bcrypt, scrypt, Argon2.\n\n<em>Applications:</em> Password storage, file encryption, secure authentication.`,
        link: "https://en.wikipedia.org/wiki/Key_derivation_function"
      },
      'file-encryption-lab': {
        title: "File Encryption Lab",
        description: "Interactive lab to try file encryption techniques.",
        details: `The File Encryption Lab lets you encrypt and decrypt files using different algorithms. You can see how symmetric and asymmetric encryption work, and learn about key management.\n\n<em>Try it:</em> Encrypt a file with AES, then try decrypting it with the correct key!` ,
        link: "/file-encryption-lab"
      },
      'applied-crypto': {
        title: "Applied Cryptography",
        description: "A classic book by Bruce Schneier on cryptographic protocols and algorithms.",
        details: `This book is a comprehensive guide to practical cryptography, covering protocols, algorithms, and real-world applications. It is widely regarded as a must-read for anyone interested in the field.\n\n<em>Topics:</em> Block ciphers, stream ciphers, public key cryptography, protocols, and more.`,
        link: "https://en.wikipedia.org/wiki/Applied_Cryptography"
      },
      'crypto-engineering': {
        title: "Cryptography Engineering",
        description: "Book by Ferguson, Schneier, and Kohno on building secure systems.",
        details: `This book focuses on the practical aspects of implementing cryptography securely in software and hardware. It covers common pitfalls, best practices, and real-world case studies.\n\n<em>Topics:</em> Key management, random number generation, secure protocols, and implementation attacks.`,
        link: "https://en.wikipedia.org/wiki/Cryptography_Engineering"
      }
    };
    document.querySelectorAll('.resource-chip').forEach(chip => {
      chip.addEventListener('click', function(e) {
        const href = chip.getAttribute('href');
        if (href && href.startsWith('#')) {
          e.preventDefault();
          const key = href.substring(1);
          const data = resourceDetails[key];
          if (data) {
            document.getElementById('resource-modal-body').innerHTML = `
              <h2>${data.title}</h2>
              <p><strong>${data.description}</strong></p>
              <p>${data.details}</p>
              <a href="${data.link}" target="_blank">Learn more</a>
            `;
            document.getElementById('resource-modal').style.display = 'flex';
          }
        }
      });
    });
    document.getElementById('resource-modal-close').onclick = function() {
      document.getElementById('resource-modal').style.display = 'none';
    };
    window.onclick = function(event) {
      if (event.target == document.getElementById('resource-modal')) {
        document.getElementById('resource-modal').style.display = 'none';
      }
    };
  </script>
</body>
</html>