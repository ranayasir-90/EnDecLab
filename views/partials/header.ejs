  "name": "EnDecLab",
  "url": "https://endeclab.xyz",
  "logo": "https://endeclab.xyz/images/logo.webp",
  "description": "Interactive cryptography and cybersecurity learning platform with hands-on labs for cipher techniques, digital signatures, steganography, and file encryption.",
