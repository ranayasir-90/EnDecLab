  <%- include('partials/footer') %>
  <script src="/js/ciphers.js"></script>
  <script>
    // Cipher card navigation
    document.addEventListener('DOMContentLoaded', function() {
      const cipherCards = document.querySelectorAll('.cipher-card-modern[data-cipher]');
      cipherCards.forEach(card => {
        card.addEventListener('click', function() {
          const cipherType = this.getAttribute('data-cipher');
          const cipherTab = document.querySelector(`[data-cipher="${cipherType}"]`);
          if (cipherTab) {
            cipherTab.click();
          }
        });
        card.style.cursor = 'pointer';
      });
    });

    // Scroll-triggered card animation for cipher cards
    document.addEventListener('DOMContentLoaded', function() {
      const cards = document.querySelectorAll('.cipher-card-modern');
      const observer = new window.IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      cards.forEach(card => observer.observe(card));
    });
    // Scroll-triggered animation for transformation steps
    document.addEventListener('DOMContentLoaded', function() {
      const steps = document.querySelectorAll('.visualization-container .step');
      const observer = new window.IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      steps.forEach(step => observer.observe(step));
    });
    // Scroll-triggered animation for cipher info cards
    document.addEventListener('DOMContentLoaded', function() {
      const infos = document.querySelectorAll('.info-content');
      const observer = new window.IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      infos.forEach(info => observer.observe(info));
    });
  </script>
</body>
</html>