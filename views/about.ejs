<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>About EnDecLab | Interactive Cryptography Learning Platform | Muhammad Yasir</title>
  
  <!-- Page-specific SEO -->
  <meta name="description" content="About EnDecLab - Interactive Cryptography Learning Platform created by Muhammad Yasir. Discover our mission to provide hands-on cryptography education through interactive labs.">
  <meta name="keywords" content="about EnDecLab, Muhammad Yasir, cryptography platform, interactive learning, security education, developer portfolio, cryptography tools, educational platform, cybersecurity learning">
  
  <!-- Open Graph for About -->
  <meta property="og:title" content="About EnDecLab | Interactive Cryptography Learning Platform">
  <meta property="og:description" content="Learn about EnDecLab - An interactive cryptography learning platform offering classical ciphers, digital signatures, steganography, and file encryption labs.">
  <meta property="og:url" content="https://endeclab.xyz/about">
  
  <!-- Twitter Card for About -->
  <meta property="twitter:title" content="About EnDecLab | Interactive Cryptography Learning Platform">
  <meta property="twitter:description" content="Learn about EnDecLab - An interactive cryptography learning platform offering classical ciphers, digital signatures, steganography, and file encryption labs.">
  
  <!-- Canonical URL -->
  <link rel="canonical" href="https://endeclab.xyz/about">
  
  <%- include('partials/head') %>
  
  <!-- About Page Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "About EnDecLab",
    "description": "Learn about EnDecLab - An interactive cryptography learning platform offering classical ciphers, digital signatures, steganography, and file encryption labs",
    "url": "https://endeclab.xyz/about",
    "mainEntity": {
      "@type": "Organization",
      "name": "EnDecLab",
      "url": "https://endeclab.xyz/",
      "description": "Interactive cryptography learning platform"
    }
  }
  </script>
</head>
<body class="about">
  <%- include('partials/header') %>
  <main>
    <!-- Hero Section -->
    <section class="about-hero-modern">
      <div class="hero-modern-content">
        <div class="hero-modern-left">
          <h1 class="hero-title-gradient">EnDecLab</h1>
          <div class="hero-tagline">Interactive Cryptography & Data Security Lab</div>
          <div class="hero-intro">Experiment, learn, and master encryption, signatures, and steganography with hands-on tools designed for students and educators.</div>
          <a href="/" class="hero-cta-modern">Try the Lab</a>
        </div>
        <div class="hero-modern-right">
          <img src="/images/logo.webp" alt="EnDecLab Logo" class="hero-logo-img" />
        </div>
      </div>
    </section>

    <!-- Why EnDecLab Section -->
    <section class="why-section">
      <h2>Why EnDecLab?</h2>
      <div class="why-points">
        <div class="why-point border1">
          <div class="icon">🔒</div>
          <p>Hands-on cryptography tools for real learning, not just theory.</p>
        </div>
        <div class="why-point border2">
          <div class="icon">⚡</div>
          <p>Instant feedback and interactive simulations for every concept.</p>
        </div>
        <div class="why-point border3">
          <div class="icon">📚</div>
          <p>Guides, walkthroughs, and resources to master encryption and security.</p>
        </div>
      </div>
    </section>

    <!-- Features Row -->
    <section class="features-row">
      <div class="feature-mini border1">
        <div class="icon">🧮</div>
        <h4>Classic Ciphers</h4>
        <p>Caesar, Affine, Rail Fence, and more.</p>
      </div>
      <div class="feature-mini border2">
        <div class="icon">📝</div>
        <h4>Digital Signatures</h4>
        <p>Key generation & signature verification.</p>
      </div>
      <div class="feature-mini border3">
        <div class="icon">🖼️</div>
        <h4>Steganography</h4>
        <p>Hide messages in images securely.</p>
      </div>
      <div class="feature-mini border4">
        <div class="icon">📁</div>
        <h4>File Encryption</h4>
        <p>Encrypt PDFs, ZIPs, DOCX with AES.</p>
      </div>
    </section>

    <!-- Meet the Creator -->
    <section class="creator-card">
      <div class="creator-card-inner">
        <div class="creator-card-front">
          <img src="/images/yasir.webp" alt="Muhammad Yasir" class="creator-img">
          <div class="creator-name">Muhammad Yasir</div>
          <div class="creator-title">Founder & Developer</div>
        </div>
        <div class="creator-card-back">
          <div class="creator-name">Muhammad Yasir</div>
          <div class="creator-role">Web Developer | Penetration Tester</div>
          
          <div class="creator-bio">I'm a web developer and penetration tester. I'm passionate about cryptography, security, and building interactive learning tools.</div>
          <div class="creator-socials">
            <a href="https://linkedin.com/in/muhammad-yasir-1b1b1b1b" target="_blank" title="LinkedIn"><svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-10h3v10zm-1.5-11.268c-.966 0-1.75-.784-1.75-1.75s.784-1.75 1.75-1.75 1.75.784 1.75 1.75-.784 1.75-1.75 1.75zm15.5 11.268h-3v-5.604c0-1.337-.025-3.063-1.868-3.063-1.868 0-2.154 1.459-2.154 2.968v5.699h-3v-10h2.881v1.367h.041c.401-.761 1.381-1.563 2.844-1.563 3.043 0 3.604 2.004 3.604 4.609v5.587z"/></svg></a>
            <a href="mailto:yasir@example.com" title="Email"><svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path d="M12 13.065l-11.985-7.065v14h23.97v-14l-11.985 7.065zm11.985-9.065h-23.97l11.985 7.065 11.985-7.065z"/></svg></a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
  <script>
    // Scroll-triggered card animation
    document.addEventListener('DOMContentLoaded', function() {
      const cards = document.querySelectorAll('.why-point, .feature-mini, .creator-card');
      const observer = new window.IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      cards.forEach(card => observer.observe(card));
    });
  </script>
</body>
</html>